{
    "layer": "top", 
    "position": "top", 
    "height": 60, 
    "spacing": 24, 
    
    "modules-left": [
        "hyprland/language",
        "hyprland/workspaces"
    ],

    "modules-right": [
        "custom/vpn",
        "custom_dot",
        "pulseaudio",
        "custom/dot",
        "custom/gpu_temp",
        "custom/dot",
        "memory",
        "custom/dot",
        "cpu", 
        "custom/dot",
        "clock",
        "custom/dot",
        "custom/gentoo-user"
    ],
    
    "pulseaudio": {
    "format": "<span color=\"#4284a7\">󰕾</span> {volume}%",
    },

    "hyprland/workspaces": {
        // "format": "<span color=\"#808080\">· </span> {icon}",
        "format": "{icon}",
        "format-icons": {
	          "1": "一",
	          "2": "二",
	          "3": "三",
	          "4": "四",
	          "5": "五",
            "6": "六",
            "7": "七",
            "8": "八",
            "9": "九",
            "10": "十"
	      },
        "persistent-workspaces": {
             "*": 6
        },
    },

    "hyprland/language": {
        "format": " 󰗊 {} ",
        "format-en": "US",
        "format-ru": "RU",
        "keyboard-name": "gaming-keyboard"
    },

    "clock": {
        "format": "<span color=\"#569F54\">󰥔  </span>{:%H:%M %A %b, %d}",
        "tooltip": false 
    },

    "cpu": {
        "format": "<span color=\"#F0C674\"> </span> {usage}%",
        "tooltip": false
    },

    "memory": {
        "format": "<span color=\"#9DC891\"> </span>{}%"
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}°C {icon}",
        "format-icons": ["", "", ""]
    },

    "custom/gentoo-user": {
        "format" : " {icon}<span style=\"italic\">Gentoo</span> ",
        "format-icons" : [" "]
    },

    "custom/dot": {
        "format" : "·",
        "tooltip" : false
    },
    "custom/vpn": {
        "format": "<span color=\"#569F54\">󰕥</span> VPN",
        "exec": "echo '{\"class\": \"connected\"}'",
        "exec-if": "test -d /proc/sys/net/ipv4/conf/wg0",
        "return-type": "json",
        "interval": 5
    },
    "custom/gpu_temp": {
        "format": "<span font='30' color='#569F54'>󰢮</span><span letter_spacing='12000'> </span><span font='Jet Brains Mono 21' rise='4000'>{}°C</span>",
        "exec" : "echo $(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader)",
        "tooltip": false,
        "interval": 10
    }
}

